// ==================== MAIN ====================
void main(void)
{
    int temperatura;
    unsigned int contador = 0;

    WDTCTL = WDTPW | WDTHOLD;

    configurarUART();

    enviarCadena("\r\n========================================\r\n");
    enviarCadena("   ESP32 + ARDUINO Mega + ARDUINO Nano\r\n");
    enviarCadena("========================================\r\n");

    initI2C();

    while(1)
    {
        contador++;

        // Enviar "Hola" al Arduino (solo la primera vez o cada cierto tiempo)
        if(contador == 1 || contador % 10 == 0) {
            enviarAArduinoMEGA("Hola MEGA desde MSP430");
            enviarAArduinoNano("Hola NANO desde MSP430");
            enviarAESP32("Hola ESP32 desde MSP430");
        }
        delay_ms(500);
    }
}
