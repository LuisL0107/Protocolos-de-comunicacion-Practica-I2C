#include <msp430f5529.h>

// ==================== DEFINICIONES ====================
#define ESP32_ADDR          0x0A    // Dirección del ESP32
#define ARDUINOMEGA_ADDR    0x09    // Dirección del Arduino mega
#define ARDUINONANO_ADDR    0x08    // Dirección del Arduino Nano

// ==================== PROTOTIPOS ====================
// UART
void configurarUART(void);
void enviarChar(char c);
void enviarCadena(const char *str);
void enviarNumero(int num);
void delay_ms(unsigned int ms);

// I2C
void initI2C(void);
void I2C_Start(void);
void I2C_Stop(void);
unsigned char I2C_WriteByte(unsigned char data);
void I2C_ReadBytes(unsigned char *buffer, unsigned char len);


// Arduino I2C y ESP32
void enviarAArduinoNano(const char *str);
void enviarAArduinoMEGA(const char *str);
void enviarAESP32(const char *str);

// ==================== UART ====================
void configurarUART(void)
{
    P4SEL |= BIT4 + BIT5;

    UCA1CTL1 |= UCSWRST;
    UCA1CTL0 = 0x00;
    UCA1CTL1 |= UCSSEL_1;
    UCA1BR0 = 3;
    UCA1BR1 = 0;
    UCA1MCTL = UCBRS_3;
    UCA1CTL1 &= ~UCSWRST;
}

void enviarChar(char c)
{
    while(!(UCA1IFG & UCTXIFG));
    UCA1TXBUF = c;
}

void enviarCadena(const char *str)
{
    while(*str) enviarChar(*str++);
}

void enviarNumero(int num)
{
    char buffer[8];
    char *ptr = buffer + 7;
    unsigned int n;

    *ptr = '\0';

    if(num < 0) {
        enviarChar('-');
        n = -num;
    } else {
        n = num;
    }

    do {
        *(--ptr) = '0' + (n % 10);
        n /= 10;
    } while(n > 0);

    enviarCadena(ptr);
}

void delay_ms(unsigned int ms)
{
    unsigned int i, j;
    for(i = 0; i < ms; i++) {
        for(j = 0; j < 500; j++) {
            __delay_cycles(2);
        }
    }
}

// ==================== I2C ====================
void initI2C(void)
{
    P4SEL |= BIT1 + BIT2;

    UCB1CTL1 |= UCSWRST;
    UCB1CTL0 = UCMST + UCMODE_3 + UCSYNC;
    UCB1CTL1 = UCSSEL_2 + UCSWRST;
    UCB1BR0 = 30;
    UCB1BR1 = 0;
    UCB1CTL1 &= ~UCSWRST;

    delay_ms(50);
}

void I2C_Start(void)
{
    while(UCB1CTL1 & UCTXSTP);
    UCB1CTL1 |= UCTR + UCTXSTT;
}

void I2C_Stop(void)
{
    UCB1CTL1 |= UCTXSTP;
    while(UCB1CTL1 & UCTXSTP);
}

unsigned char I2C_WriteByte(unsigned char data)
{
    UCB1TXBUF = data;
    while(!(UCB1IFG & UCTXIFG));
    if(UCB1IFG & UCNACKIFG) {
        UCB1IFG &= ~UCNACKIFG;
        return 1;
    }
    return 0;
}

void I2C_ReadBytes(unsigned char *buffer, unsigned char len)
{
    unsigned char i;
    UCB1CTL1 &= ~UCTR;
    UCB1CTL1 |= UCTXSTT;

    for(i = 0; i < len; i++) {
        if(i == len-1) UCB1CTL1 |= UCTXSTP;
        while(!(UCB1IFG & UCRXIFG));
        buffer[i] = UCB1RXBUF;
    }
}

// ==================== COMUNICACIÓN CON ARDUINO Nano ====================
void enviarAArduinoNano(const char *str)
{
    UCB1I2CSA = ARDUINONANO_ADDR;

    I2C_Start();
    if(I2C_WriteByte(0x00)) {  // Enviar dirección (puede ser 0x00 o cualquier registro dummy)
        enviarCadena("[ARDUINO NANO] Error: No ACK\r\n");
        I2C_Stop();
        return;
    }

    // Enviar cada caracter del string
    while(*str) {
        if(I2C_WriteByte(*str++)) {
            enviarCadena("[ARDUINO NANO] Error enviando datos\r\n");
            I2C_Stop();
            return;
        }
        delay_ms(1);  // Pequeña pausa entre caracteres
    }

    I2C_Stop();
    enviarCadena("[ARDUINO NANO] Mensaje enviado\r\n");
}

