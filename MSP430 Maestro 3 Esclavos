#include <msp430f5529.h>

// ==================== DEFINICIONES ====================
#define BMP280_ADDR     0x76    // Dirección del BMP280
#define OLED_ADDR       0x3C    // Dirección de la OLED (ajusta según tu escáner)
#define ARDUINO_ADDR    0x08    // Dirección del Arduino (configurable)

// ==================== FUENTE SIMPLIFICADA 5x8 ====================
// Solo: números 0-9, punto, C, espacio, menos
const unsigned char font[17][5] = {
    {0x00, 0x00, 0x00, 0x00, 0x00}, // 0: espacio
    {0x3E, 0x51, 0x49, 0x45, 0x3E}, // 1: '0'
    {0x00, 0x42, 0x7F, 0x40, 0x00}, // 2: '1'
    {0x42, 0x61, 0x51, 0x49, 0x46}, // 3: '2'
    {0x21, 0x41, 0x45, 0x4B, 0x31}, // 4: '3'
    {0x18, 0x14, 0x12, 0x7F, 0x10}, // 5: '4'
    {0x27, 0x45, 0x45, 0x45, 0x39}, // 6: '5'
    {0x3C, 0x4A, 0x49, 0x49, 0x30}, // 7: '6'
    {0x01, 0x71, 0x09, 0x05, 0x03}, // 8: '7'
    {0x36, 0x49, 0x49, 0x49, 0x36}, // 9: '8'
    {0x06, 0x49, 0x49, 0x29, 0x1E}, // 10: '9'
    {0x00, 0x60, 0x60, 0x00, 0x00}, // 11: '.'
    {0x00, 0x00, 0x00, 0x00, 0x00}, // 12: reservado
    {0x00, 0x00, 0x00, 0x00, 0x00}, // 13: reservado
    {0x3E, 0x41, 0x41, 0x41, 0x3E}, // 14: 'O' (para grados Celsius)
    {0x08, 0x08, 0x08, 0x08, 0x08}, // 15: '-'
    {0x00, 0x00, 0x00, 0x00, 0x00}, // 16: reservado
};

